# Valentina Web - Environment Configuration
# Copy this file to .env.secret and update the values for your environment.

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────

# Display name shown in the UI and templates.
VWEB_APP_NAME=

# "production" to enforce stricter settings
# "development" to enable verbose error pages and auto-reloading
# Valid values: development, production
# VWEB_ENV=production

# Enable the flask debug toolbar (only in development)
# VWEB_DEBUG_TOOLBAR=false

# Secret key for signing sessions and cookies. Generate a strong random value
# for production (e.g., `python -c "import secrets; print(secrets.token_hex(32))"`).
VWEB_SECRET_KEY=

# Network interface and port the server binds to.
# Inside a container, set VWEB_HOST=0.0.0.0 so gunicorn is reachable from
# outside (the default 127.0.0.1 binds to the container's loopback only).
# VWEB_HOST=127.0.0.1
# VWEB_PORT=8089

# Number of gunicorn worker processes (production only).
# Default: (2 × CPU cores) + 1
# VWEB_WORKERS=


# ──────────────────────────────────────────────
# Redis (VWEB_REDIS__*)
# ──────────────────────────────────────────────
# Shared by Flask-Caching and Flask-Session. When VWEB_REDIS__URL is set it
# takes precedence; otherwise the individual host/port/password/db fields are
# used.

# Required when VWEB_ENV=production. Full Redis connection URL.
# VWEB_REDIS__URL=redis://127.0.0.1:6379/0

# Default cache entry timeout in seconds. Default: 300
# VWEB_REDIS__DEFAULT_TIMEOUT=300

# Prefix prepended to all cache keys. Default: vweb:
# VWEB_REDIS__KEY_PREFIX=vweb:

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────

# ASGI server access log destination. Use "-" for stdout or a file path.
# VWEB_ACCESS_LOG=-


# Valid values: TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
# VWEB_LOG_LEVEL=INFO

# Optional: write logs to a file in addition to stderr. Leave empty to disable.
# VWEB_LOG_FILE_PATH=

# ──────────────────────────────────────────────
# Valentina API (VWEB_VCLIENT__*)
# ──────────────────────────────────────────────
# These configure the valentina-python-client used to communicate with the
# Valentina API. The double-underscore delimiter maps to nested config fields.

# Required - base URL of the Valentina API.
VWEB_API__BASE_URL=

# Required - API key for authenticating with the Valentina API.
VWEB_API__API_KEY=

# Required - Default company ID for API requests.
VWEB_API__DEFAULT_COMPANY_ID=

# Required - Server admin user ID used for user creation during OAuth.
# If you don't have, contact support@valentina-noir.com
VWEB_API__SERVER_ADMIN_USER_ID=

# Request timeout in seconds. Default: 10.0
# VWEB_API__TIMEOUT=10.0

# Maximum number of retry attempts for failed requests. Default: 5
# VWEB_API__MAX_RETRIES=5

# Seconds to wait between retries. Default: 1.0
# VWEB_API__RETRY_DELAY=1.0

# Automatically retry when the API returns a rate-limit response. Default: true
# VWEB_API__AUTO_RETRY_RATE_LIMIT=true

# Automatically attach idempotency keys to mutating requests. Default: true
# VWEB_API__AUTO_IDEMPOTENCY_KEYS=true

# Log HTTP requests and responses from the API client. Default: false
# VWEB_API__ENABLE_LOGS=false

# ──────────────────────────────────────────────
# OAuth (VWEB_OAUTH__*)
# ──────────────────────────────────────────────
# OAuth provider credentials for authentication.

# Discord OAuth credentials. Register at https://discord.com/developers/applications
VWEB_OAUTH__DISCORD__CLIENT_ID=
VWEB_OAUTH__DISCORD__CLIENT_SECRET=

# GitHub OAuth credentials. Register at https://github.com/settings/developers
VWEB_OAUTH__GITHUB__CLIENT_ID=
VWEB_OAUTH__GITHUB__CLIENT_SECRET=

# Google OAuth credentials. Register at https://console.cloud.google.com/apis/credentials
VWEB_OAUTH__GOOGLE__CLIENT_ID=
VWEB_OAUTH__GOOGLE__CLIENT_SECRET=

# ──────────────────────────────────────────────
# Docker runtime
# ──────────────────────────────────────────────
# Used only when running via Dockerfile / compose.yaml.

# UID/GID the container process drops to. Match the host user that owns
# any bind-mounted directories.
# PUID=1000
# PGID=1000
