{#def pending, approved #}
<shared.PageLayout title="Members">
  <div class="max-w-3xl mx-auto p-4 flex flex-col gap-4">

    <shared.layout.CompanyChrome active="members" />

    <h1 class="sr-only">Members</h1>

    {% if pending %}
      <div class="card surface-card">
        <div class="card-body">
          <h2 class="card-title">
            Pending Approval
            <span class="badge badge-warning">{{ pending|length }}</span>
          </h2>
          <div id="pending-users">
            {% for u in pending %}
              <admin.components.PendingUserRow user={{ u }} />
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="card surface-card">
      <div class="card-body">
        <h2 class="card-title">Members</h2>
        <div id="approved-users">
          {% for u in approved %}
            <admin.components.ApprovedUserRow user={{ u }} />
          {% endfor %}
        </div>
      </div>
    </div>

    <div id="merge-modal-slot"></div>
  </div>
</shared.PageLayout>
