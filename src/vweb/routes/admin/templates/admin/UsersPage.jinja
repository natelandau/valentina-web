{#def pending, approved, pending_count=0 #}
{% set current_campaign = active_campaign() %}
<shared.PageLayout title="User Management">
  <div class="max-w-3xl mx-auto p-4 flex flex-col gap-4">

    {% if current_campaign %}
      <shared.layout.CampaignChrome
          campaign={{ current_campaign }}
          active="admin"
          show_admin={{ is_admin() }} />
    {% endif %}

    <h1 class="sr-only">User Management</h1>

    <admin.components.AdminTabs active="users" pending_count={{ pending_count }} />

    {% if pending %}
      <div class="card surface-card">
        <div class="card-body">
          <h2 class="card-title">
            Pending Approval
            <span class="badge badge-warning">{{ pending|length }}</span>
          </h2>
          <div id="pending-users">
            {% for u in pending %}
              <admin.components.PendingUserRow user={{ u }} />
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="card surface-card">
      <div class="card-body">
        <h2 class="card-title">Users</h2>
        <div id="approved-users">
          {% for u in approved %}
            <admin.components.ApprovedUserRow user={{ u }} />
          {% endfor %}
        </div>
      </div>
    </div>

    <div id="merge-modal-slot"></div>
  </div>
</shared.PageLayout>
