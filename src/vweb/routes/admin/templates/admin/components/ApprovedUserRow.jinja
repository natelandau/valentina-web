{#def user #}
<div id="user-{{ user.id }}"
     class="flex flex-col sm:flex-row sm:items-center gap-3 py-3 border-b border-base-300">
  <div class="flex items-center gap-3 grow min-w-0">
    <shared.UserAvatar user={{ user }} size="w-10" />
    <div class="min-w-0">

      {% set display_name = user.name_first ~ " " ~ user.name_last or "" if user.name_first else user.username %}

      <div class="font-medium truncate">{{ display_name }}</div>
      <div class="text-sm text-base-content/70 truncate">
        {{ user.email }}
      </div>
    </div>
  </div>
  <select name="role"
          class="select select-sm w-full sm:w-auto"
          hx-post="{{ url_for('admin.change_role', user_id=user.id) }}"
          hx-target="#user-{{ user.id }}"
          hx-swap="outerHTML"
          hx-include="this">
    <option value="PLAYER" {% if user.role == "PLAYER" %}selected{% endif %}>
      Player
    </option>
    <option value="STORYTELLER"
            {% if user.role == "STORYTELLER" %}selected{% endif %}>
      Storyteller
    </option>
    <option value="ADMIN" {% if user.role == "ADMIN" %}selected{% endif %}>
      Admin
    </option>
  </select>
</div>
