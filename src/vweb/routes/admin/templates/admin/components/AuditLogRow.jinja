{#def log, entities, acting_user_name="", acting_user_url="" #}
<tr class="hover:bg-base-200">
  <td class="whitespace-nowrap text-sm text-base-content/70">
    {{ log.date_created.strftime("%b %d, %Y %-I:%M %p") }}
  </td>
  <td class="text-sm">{{ log.description or log.summary or "" }}</td>
  <td class="text-sm">
    {% if log.changes %}
      <ul class="list-disc pl-4 text-base-content/60 text-xs">
        {% for key, value in log.changes.items() %}
          <li>{{ key }}: {{ value }}</li>
        {% endfor %}
      </ul>
    {% else %}
      <span class="text-base-content/40 italic text-xs">&mdash;</span>
    {% endif %}
  </td>
  <td class="text-sm">
    {% if acting_user_url %}
      <a href="{{ acting_user_url }}" class="link link-primary">{{ acting_user_name }}</a>
    {% elif acting_user_name %}
      {{ acting_user_name }}
    {% else %}
      <span class="text-base-content/40 italic text-xs">system</span>
    {% endif %}
  </td>
  <td class="text-sm">
    {% for label, name, url in entities %}
      <div>
        <span class="text-base-content/50 text-xs">{{ label }}:</span>
        {% if url %}
          <a href="{{ url }}" class="link link-primary text-xs">{{ name }}</a>
        {% else %}
          <span class="text-xs">{{ name }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </td>
</tr>
