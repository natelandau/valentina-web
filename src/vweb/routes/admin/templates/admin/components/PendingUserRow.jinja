{#def user #}
<div id="pending-user-{{ user.id }}"
     class="flex flex-col sm:flex-row sm:items-center gap-3 py-3 border-b border-base-300">
  <div class="flex items-center gap-3 grow min-w-0">
    <shared.UserAvatar user={{ user }} size="w-10" />
    <div class="min-w-0">
      {% set display_name = (user.name_first ~ " " ~ user.name_last) if user.name_first and user.name_last else user.username %}
      <div class="font-medium truncate">{{ display_name }}</div>
      <div class="text-sm text-base-content/70 truncate">{{ user.email }}</div>
    </div>
  </div>
  <div class="flex flex-wrap items-center gap-2 shrink-0">
    <form class="flex items-center gap-2 grow sm:grow-0"
          hx-post="{{ url_for('admin.approve_user', user_id=user.id) }}"
          hx-target="#pending-user-{{ user.id }}"
          hx-swap="outerHTML">
      <select name="role" class="select select-sm grow sm:grow-0">
        <option value="PLAYER" selected>Player</option>
        <option value="STORYTELLER">Storyteller</option>
        <option value="ADMIN">Admin</option>
      </select>
      <button type="submit" class="btn btn-sm btn-primary">Approve</button>
    </form>
    <button class="btn btn-sm btn-outline"
            hx-get="{{ url_for('admin.merge_form', user_id=user.id) }}"
            hx-target="#merge-modal-slot"
            hx-swap="innerHTML">Merge…</button>
    <button class="btn btn-sm btn-error btn-outline"
            hx-post="{{ url_for('admin.deny_user', user_id=user.id) }}"
            hx-target="#pending-user-{{ user.id }}"
            hx-swap="outerHTML"
            hx-confirm="Deny {{ user.name_first }}? This cannot be undone.">
      Deny
    </button>
  </div>
</div>
