<shared.PageLayout title="Welcome">
<div class="hero min-h-[60vh]">
  <div class="hero-content flex-col md:flex-row gap-12">
    <img src="https://cdn.valentina-noir.com/assets/valentina512.png"
         alt="Valentina"
         class="max-w-xs rounded-lg shadow-2xl" />
    <div class="text-center md:text-left max-w-md">
      <h1 class="text-5xl font-bold">{{ app_name }}</h1>
      <p class="py-6">
        Manage your World of Darkness games. Character management, dice rolling, campaign management, and more.
      </p>
      <div class="flex flex-col gap-3">
