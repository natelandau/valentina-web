{#def companies: dict #}
<shared.PageLayout title="Select Company">
    <div class="hero min-h-[60vh]">
        <div class="hero-content text-center">
            <div class="max-w-lg">
                <h1 class="text-3xl font-bold mb-6">Select a Company</h1>
                <div class="space-y-3">
                    {% for company_id, data in companies.items() %}
                        <form method="post" action="{{ url_for('auth.select_company') }}">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}" />
                            <input type="hidden" name="company_id" value="{{ company_id }}" />
                            <button type="submit" class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md transition-shadow w-full cursor-pointer">
                                <div class="card-body flex-row items-center justify-between py-4">
                                    <span class="font-medium text-lg">{{ data.company_name }}</span>
                                    <span class="badge badge-outline">{{ data.role }}</span>
                                </div>
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</shared.PageLayout>
