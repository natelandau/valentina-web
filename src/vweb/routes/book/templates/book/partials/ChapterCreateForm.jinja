{#def
    book: object,
    campaign: object,
    target_id: str = "book-chapters-card",
    cancel_url: str = "",
    from_chapter: str = "",
    errors: list = [],
    form_data: object = None,
#}
<div id="{{ target_id }}" class="card surface-card">
  <div class="card-body">
    <h2 class="card-title">Add Chapter</h2>

    {% if errors %}
      <div class="mb-2">
        {% for error in errors %}
          <div class="alert alert-error alert-sm mb-1">{{ error }}</div>
        {% endfor %}
      </div>
    {% endif %}

    <form hx-post="{{ url_for('chapter_view.chapter_create', campaign_id=campaign.id, book_id=book.id) }}"
          hx-target={{ "#" ~ target_id }}
          hx-swap="outerHTML">
      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
      <input type="hidden" name="from_chapter" value="{{ from_chapter | e }}">

      <fieldset class="fieldset mb-4">
        <legend class="fieldset-legend">Name</legend>
        <label class="input w-full">
          <input type="text"
                 name="name"
                 value="{{ (form_data.get('name', '') if form_data else '') | e }}"
                 class="grow"
                 required
                 minlength="1"
                 maxlength="100"
                 placeholder="Chapter name">
        </label>
      </fieldset>

      <fieldset class="fieldset mb-4">
        <legend class="fieldset-legend">Description</legend>
        <textarea name="description"
                  class="textarea w-full"
                  rows="4"
                  placeholder="Chapter description (optional)...">{{ (form_data.get('description', '') if form_data else '') | e }}</textarea>
      </fieldset>

      <div class="flex gap-2 justify-end">
        <shared.CommonButton variant="cancel" hx-get={{ cancel_url }} hx-target={{ "#" ~ target_id }} hx-swap="outerHTML" hx-select={{ "#" ~ target_id }}>
        Cancel
        </shared.CommonButton>
        <shared.CommonButton variant="submit">Create</shared.CommonButton>
      </div>
    </form>
  </div>
</div>
