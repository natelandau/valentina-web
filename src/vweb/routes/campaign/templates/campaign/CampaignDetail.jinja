{# def
    campaign = None,
    campaign_experience = None,
    user: User = None,
#}

<shared.PageLayout title="Home">
<div class="flex flex-col gap-6">

  <shared.layout.CampaignBand active="overview" campaign_id={{ campaign.id }} show_admin={{ is_admin() }}>
  <campaign.components.CampaignSummaryCard campaign={{ campaign }} />
  </shared.layout.CampaignBand>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <shared.cards.CharacterListCard title="Your Characters" campaign_id={{ campaign.id }} bucket="mine" show_type={{ true }} show_add_button={{ true }} show_filters={{ false }} empty_message="No characters in this campaign" page_size={{ 5 }} card_id="your-characters" />

    <campaign.components.UserListCard title="All Players" users={{ g.global_context.users }} page_size={{ 3 }} campaign_id={{ campaign.id }} />

    <shared.cards.CharacterListCard title="Other Players' Characters" campaign_id={{ campaign.id }} bucket="others" show_type={{ true }} empty_message="No other players' characters" page_size={{ 5 }} link_user_profile={{ true }} card_id="other-characters" />

    {% if is_storyteller() %}
      <shared.cards.AuditLog campaign_id={{ campaign.id }} col_span={{ 2 }} page_size={{ 5 }} title="Recent Activity" />
    {% endif %}

    <shared.cards.RecentDiceRolls campaign_id={{ campaign.id }} col_span={{ 1 }} />
    <shared.cards.Statistics campaign_id={{ campaign.id }} col_span={{ 2 }} />

  </div>
</div>
{% if can_manage_campaign() %}
  <campaign.components.CampaignDeleteModal campaign_id={{ campaign.id }} campaign_name={{ campaign.name }} />
{% endif %}
<shared.diceroll.DiceRollModal />
</shared.PageLayout>
