{#def
    campaign,
    books: list = [],
    chapter_count: int = 0
#}

<div id="campaign-summary-card">
  <div class="p-4 sm:p-6">
    <div class="flex flex-col lg:flex-row lg:gap-6">

      <div class="min-w-0 flex-1 flex flex-col gap-3">
        <div class="text-xs uppercase tracking-wider opacity-60">Campaign</div>
        <h1 class="text-3xl font-bold leading-tight">{{ campaign.name }}</h1>

        {% if campaign.description %}
          <div x-data="{ expanded: false, overflows: false }"
               x-init="$nextTick(() => { overflows = $refs.desc.scrollHeight > $refs.desc.clientHeight + 1 })">
            <div x-ref="desc"
                 :class="{ 'line-clamp-2': !expanded }"
                 class="prose prose-md max-w-none text-base-content/80">
              {{ campaign.description | from_markdown }}
            </div>
            <button type="button"
                    x-show="overflows"
                    @click="expanded = !expanded"
                    class="link link-primary text-sm mt-1">
              <span x-text="expanded ? 'Show less' : 'Read more'"></span>
            </button>
          </div>
        {% endif %}

        <div class="flex flex-wrap items-center gap-2">
          {% if books %}
            <span class="badge badge-outline badge-sm">
              {{ books|length }} books · {{ chapter_count }} chapters
            </span>
          {% endif %}
          <span class="badge badge-outline badge-sm">
            {{ campaign.date_created.strftime("Started %b %Y") }}
          </span>
        </div>
      </div>

      <div class="flex flex-col gap-2 lg:shrink-0 lg:items-end mt-3 lg:mt-0">
        <campaign.partials.DangerDesperation campaign={{ campaign }} vertical={{ true }} />

        {% if can_manage_campaign() %}
          <div class="flex items-center gap-1 mt-2">
            <button class="btn btn-sm"
                    hx-get="{{ url_for('campaign.edit_form', campaign_id=campaign.id) }}"
                    hx-target="#campaign-create-modal .modal-box"
                    hx-swap="innerHTML"
                    x-data
                    @click="document.getElementById('campaign-create-modal').showModal()">
              Edit campaign
            </button>
            <details class="dropdown dropdown-end"
                     x-data
                     @click.outside="$el.removeAttribute('open')">
              <summary class="btn btn-sm btn-ghost btn-square">
                <i class="fa-solid fa-ellipsis"></i>
                <span class="sr-only">More actions</span>
              </summary>
              <ul class="menu dropdown-content bg-base-100 rounded-box z-10 w-48 p-2 shadow-md">
                <li>
                  <button class="text-error hover:bg-error/10"
                          x-data
                          @click="document.getElementById('campaign-delete-modal').showModal()">
                    <i class="fa-solid fa-trash-can"></i> Delete Campaign
                  </button>
                </li>
              </ul>
            </details>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
