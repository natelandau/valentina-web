{#def
    active: str = "overview",
    campaign_id: str = "",
    show_admin: bool = false,
    bordered: bool = true
#}

{% set items = [
  {"key": "overview",    "label": "Overview",         "url": url_for('campaign.campaign', campaign_id=campaign_id), "badge": false},
  {"key": "books",       "label": "Books & Chapters", "url": "#books",                                              "badge": false},
  {"key": "characters",  "label": "Characters",       "url": url_for('character_list.index', campaign_id=campaign_id), "badge": false},
  {"key": "players",     "label": "Players",          "url": "#players",                                            "badge": false},
  {"key": "dictionary",  "label": "Dictionary",       "url": url_for('dictionary.index'),                           "badge": false},
  {"key": "notes",       "label": "Notes",            "url": "#notes",                                              "badge": false},
] %}
{% if show_admin %}
  {% set _ = items.append({
    "key": "admin",
    "label": "Admin",
    "url": url_for('admin.audit_log'),
    "badge": global_context().pending_user_count > 0,
  }) %}
{% endif %}

<nav aria-label="Campaign sections"
     class="{% if bordered %}border-b border-base-300 {% endif %}relative"
     x-data='priorityNav({{ {"items": items, "active": active} | tojson }})'
     x-cloak>

  {# Hidden measurement row — always renders every item at its natural width so the
     layout engine can tell us what fits. Positioned off-screen, ignored by a11y. #}
  <div x-ref="measure"
       aria-hidden="true"
       class="invisible absolute -left-[9999px] top-0 flex flex-nowrap tabs tabs-border">
    {% for item in items %}
      <span data-measure-tab class="tab">
        {{ item.label }}
        {% if item.badge %}
          <shared.PingBadge extra_class="ml-2" />
        {% endif %}
      </span>
    {% endfor %}
    <span data-measure-more class="tab">
      More
      <i class="fa-solid fa-chevron-down text-xs ml-1.5"></i>
    </span>
  </div>

  <div role="tablist"
       x-ref="bar"
       class="tabs tabs-border items-stretch flex-nowrap transition-opacity duration-150"
       :class="{ 'opacity-0': !ready }">
    <template x-for="item in layout.visible" :key="item.key">
      <a role="tab"
         :href="item.url"
         class="tab"
         :class="{ 'tab-active font-semibold': item.key === active }">
        <span x-text="item.label"></span>
        <template x-if="item.badge">
          <shared.PingBadge extra_class="ml-2" />
        </template>
      </a>
    </template>

    <div class="dropdown dropdown-end ml-auto"
         :class="{ 'hidden': layout.hidden.length === 0 }"
         @click.outside="open = false"
         @keydown.escape.window="open = false">
      <button type="button"
              role="tab"
              class="tab"
              :class="{ 'tab-active': open }"
              :aria-expanded="open.toString()"
              @click="open = !open">
        <span>More</span>
        <i class="fa-solid fa-chevron-down text-xs ml-1.5 transition-transform duration-150"
           :class="{ 'rotate-180': open }"></i>
      </button>
      <ul x-show="open"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 -translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-1"
          class="menu dropdown-content bg-base-100 rounded-box z-10 w-56 p-2 mt-2 shadow-md border border-base-300">
        <template x-for="item in layout.hidden" :key="item.key">
          <li>
            <a :href="item.url"
               :class="{ 'menu-active font-semibold': item.key === active }">
              <span x-text="item.label"></span>
              <template x-if="item.badge">
                <shared.PingBadge extra_class="ml-auto" />
              </template>
            </a>
          </li>
        </template>
      </ul>
    </div>
  </div>
</nav>
