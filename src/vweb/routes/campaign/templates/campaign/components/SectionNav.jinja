{#def
    active: str = "overview",
    show_admin: bool = false
#}

{% set items = [
  {"key": "overview",    "label": "Overview"},
  {"key": "books",       "label": "Books & Chapters"},
  {"key": "characters",  "label": "Characters"},
  {"key": "players",     "label": "Players"},
  {"key": "dictionary",  "label": "Dictionary"},
  {"key": "notes",       "label": "Notes"},
] %}
{% if show_admin %}
  {% set _ = items.append({"key": "admin", "label": "Admin"}) %}
{% endif %}

<nav aria-label="Campaign sections"
     class="border-b border-base-300 relative"
     x-data='priorityNav({{ {"items": items, "active": active} | tojson }})'
     x-cloak>

  {# Hidden measurement row — always renders every item at its natural width so the
     layout engine can tell us what fits. Positioned off-screen, ignored by a11y. #}
  <div x-ref="measure"
       aria-hidden="true"
       class="invisible absolute -left-[9999px] top-0 flex flex-nowrap tabs tabs-border">
    {% for item in items %}
      <span data-measure-tab class="tab">{{ item.label }}</span>
    {% endfor %}
    <span data-measure-more class="tab">
      More
      <i class="fa-solid fa-chevron-down text-xs ml-1.5"></i>
    </span>
  </div>

  <div role="tablist"
       x-ref="bar"
       class="tabs tabs-border items-stretch flex-nowrap transition-opacity duration-150"
       :class="{ 'opacity-0': !ready }">
    <template x-for="(item, index) in items" :key="item.key">
      <a role="tab"
         :href="'#' + item.key"
         class="tab"
         :class="{ 'tab-active': item.key === active, 'hidden': isOverflow(index) }"
         x-text="item.label"></a>
    </template>

    <div class="dropdown dropdown-end ml-auto"
         :class="{ 'hidden': visibleCount >= items.length }"
         @click.outside="open = false"
         @keydown.escape.window="open = false">
      <button type="button"
              role="tab"
              class="tab relative"
              :class="{ 'tab-active': open }"
              :aria-expanded="open.toString()"
              @click="open = !open">
        <span>More</span>
        <i class="fa-solid fa-chevron-down text-xs ml-1.5 transition-transform duration-150"
           :class="{ 'rotate-180': open }"></i>
        <span class="absolute top-1.5 right-1 size-1.5 rounded-full bg-primary"
              :class="{ 'hidden': !activeInOverflow() }"
              aria-hidden="true"></span>
      </button>
      <ul x-show="open"
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 -translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-1"
          class="menu dropdown-content bg-base-100 rounded-box z-10 w-56 p-2 mt-2 shadow-md border border-base-300">
        <template x-for="(item, index) in items" :key="item.key">
          <li x-show="isOverflow(index)">
            <a :href="'#' + item.key"
               :class="{ 'menu-active': item.key === active }"
               x-text="item.label"></a>
          </li>
        </template>
      </ul>
    </div>
  </div>
</nav>
