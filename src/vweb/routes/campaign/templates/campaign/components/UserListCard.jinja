{#def
    title: str = "Users",
    users: list[User],
    card_id: str = "",
    empty_message: str = "No items found",
    col_span: int = 0,
    pagination: int = 0,
    campaign_id: str,
#}

{% set grid_col_span = "col-span-" ~ col_span if col_span > 0 else "" %}

{% set current_user = g.requesting_user %}

<div {% if card_id %}id="{{ card_id }}"{% endif %}
     class="card surface-card {{ grid_col_span }}">
  <div id="index-experience-card">
    <campaign.components.ExperienceCard campaign_id={{ campaign_id }} />
  </div>
  <div class="card-body pt-0">
    <div class="flex items-center justify-between">
      <h2 class="card-title">All Players</h2>
    </div>

    {% set filtered_users = users | rejectattr("id", "equalto", current_user.id) | list %}

    {% if filtered_users %}
      {% if pagination > 0 %}
        <div x-data="{ currentPage: 1, pageSize: {{ pagination }}, totalItems: {{ filtered_users|length }}, get totalPages() { return Math.ceil(this.totalItems / this.pageSize) }, listHeight: 0 }"
             x-init="$nextTick(() => { listHeight = $refs.list.offsetHeight })">
        {% endif %}
        <ul class="list bg-base-100 rounded-box shadow-md"
            {% if pagination > 0 %}x-ref="list" :style="listHeight ? 'min-height:' + listHeight + 'px' : ''"{% endif %}>
          {% for user in filtered_users | sort(attribute="username") %}

            {% set campaign_experience = user_campaign_experience(user.id, campaign_id) %}

            <li class="list-row hover:bg-neutral/80 hover:text-neutral-content transition-colors" {% if pagination > 0 %}x-cloak x-show="({{ loop.index0 }} >= (currentPage - 1) * pageSize) && ({{ loop.index0 }} < currentPage * pageSize)"
            {% endif %}
            >

            <div>
              <a href="{{ url_for('profile.profile', user_id=user.id) }}"><shared.UserAvatar user={{ user }} /></a>
            </div>
            <div class="list-col-grow">
              <a href="{{ url_for('profile.profile', user_id=user.id) }}">
                <div class="uppercase font-semibold text-nowrap tracking-wide">
                  {{ user.username }}
                </div>
                <div class="text-xs opacity-60 flex items-center gap-2 [&>*+*]:before:content-['·'] [&>*+*]:before:mr-2">
                  <span class="font-mono"><i class="fa-solid fa-star"></i> {{ campaign_experience.xp_current if campaign_experience else 0 }} Available XP</span>
                  <span class="font-mono">{{ campaign_experience.xp_total if campaign_experience else 0 }} Lifetime XP</span>
                  <span class="font-mono">{{ campaign_experience.cool_points if campaign_experience else 0 }} CP</span>
                </div>
              </a>
            </div>
            <div>
              <a href="{{ url_for('profile.profile', user_id=user.id) }}"
                 class="btn btn-square btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="24"
                     height="24"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     class="lucide lucide-square-arrow-up-right-icon lucide-square-arrow-up-right">
                  <rect width="18" height="18" x="3" y="3" rx="2" />
                  <path d="M8 8h8v8" />
                  <path d="m8 16 8-8" />
                </svg>
              </a>
            </div>
          </li>
        {% endfor %}
      </ul>

      {% if pagination > 0 %}
        <shared.cards.Pagination />
      </div>
    {% endif %}

  {% else %}
    <p class="text-base-content/60 text-sm">{{ empty_message }}</p>
  {% endif %}
</div>
</div>
