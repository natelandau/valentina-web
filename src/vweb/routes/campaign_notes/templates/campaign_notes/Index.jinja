{#def campaign #}

<shared.PageLayout title="Notes">
<div class="flex flex-col gap-4">

  <shared.layout.CampaignChrome
      campaign={{ campaign }}
      active="notes"
 />

  <h1 class="sr-only">Notes</h1>

  {% set editable_param = 'true' if can_manage_campaign() else 'false' %}

  <div class="card surface-card">
    <div class="card-body">
      <shared.LazyFragment target_id="crud-campaign_notes"
                           url={{ url_for('campaign_notes.notes_table', campaign_id=campaign.id) ~ "?editable=" ~ editable_param }} />
    </div>
  </div>
</div>
</shared.PageLayout>
