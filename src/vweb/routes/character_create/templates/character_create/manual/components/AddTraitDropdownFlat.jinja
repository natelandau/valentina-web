{#def
    available_traits: list[Trait],
#}
{# Alpine-driven variant for the manual-create wizard; HTMX sibling: templates/shared/traits/AddTraitDropdownFlat.jinja #}
{% if available_traits %}
  <tr>
    <td></td>
    <td class="flex justify-end">
      <select class="select select-sm w-32 mt-2"
              @change="if ($event.target.value) { selected[$event.target.value] = {{ available_traits[0].min_value }}; $event.target.value = ''; }">
        <option disabled selected value="">Add New</option>
        {% for trait in available_traits | sort(attribute="name") %}
          <option value="{{ trait.id }}"
                  x-show="!('{{ trait.id }}' in selected)"
                  :disabled="'{{ trait.id }}' in selected">
            {{ trait.name | title }}
          </option>
        {% endfor %}
      </select>
    </td>
  </tr>
{% endif %}
