{#def
    trait_id: str,
    current_value: int,
    min_value: int,
    max_value: int,
    alpine_var: str = "val",
#}

<div class="flex flex-wrap gap-y-0.5 justify-end">
  {% for row in range(min_value, max_value + 1) | batch(10) %}
    <div class="join">
      {% for i in row %}
        <button type="button"
                class="btn btn-square btn-xs btn-primary btn-outline"
                :class="{ 'btn-active': {{ alpine_var }} === {{ i }} }"
                @click="{{ alpine_var }} = {{ i }}">{{ i }}</button>
      {% endfor %}
    </div>
  {% endfor %}
</div>
