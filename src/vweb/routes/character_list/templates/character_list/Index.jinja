{#def
    campaign,
#}

<shared.PageLayout title="Characters">
<div class="flex flex-col gap-4">

  <shared.layout.CampaignChrome
      campaign={{ campaign }}
      active="characters"
 />

  <h1 class="sr-only">Characters</h1>

  <shared.cards.CharacterListCard
      title="Characters"
      campaign_id={{ campaign.id }}
      bucket="all"
      show_type={{ true }}
      link_user_profile={{ true }}
      show_add_button={{ true }}
      page_size={{ 10 }}
      card_id="campaign-characters"
      empty_message="No characters found" />
</div>

<shared.diceroll.DiceRollModal />
</shared.PageLayout>
