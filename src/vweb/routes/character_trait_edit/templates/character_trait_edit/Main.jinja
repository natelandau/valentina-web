{# def
    current_spend_type: TraitModifyCurrency,
    character: Character,
    campaign: Campaign,
    xp_current: int,
    xp_total: int,
    full_sheet: CharacterFullSheet,
    post_url: str,
#}

{% set title = character.name ~ " Manage Traits" %}

<shared.PageLayout title={{ title }}>

<div class="bg-base-200 rounded-box p-3 sm:p-4 mb-4">
  <div class="flex flex-row items-center justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-3xl font-bold">
        {{ character.name_full }}
      </h1>
      <p class="text-xs sm:text-sm text-base-content/60 uppercase tracking-wide">
        {{ character.character_class | title }}
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-1.5">
      <a href="{{ url_for('character_view.character', character_id=character.id) }}"
         class="btn btn-sm md:btn-md btn-primary btn-outline">Done Editing</a>
    </div>
  </div>
</div>

<div class="flex items-center justify-center">

  <div class="card lg:w-1/2 bg-base-100 card-lg shadow-sm">
    <div class="card-body">

      {% if current_spend_type == "NO_COST" %}
        <p>
          Storytellers can update any character without needing to spend experience.
        </p>
      {% elif current_spend_type == "XP" %}
        <p>
          Spend your experience points to update your character.  Any trait values changed downward will have its value added to your experience points.
        </p>
        <p>
          You have <span class="font-bold font-mono">{{ xp_current }}</span> experience points available.
        </p>
      {% else %}
        <p>
          Spend your starting points to update your character.  Any trait values changed downward will have its value added to your starting points.
        </p>
        <p>
          You have <span class="font-bold font-mono">{{ character.starting_points }}</span> starting points available.
        </p>
      {% endif %}

    </div>
  </div>
</div>

{% for section in full_sheet.sections %}
  <shared.traits.TraitSection section={{ section }} show_delete={{ current_spend_type == "NO_COST" }} post_url={{ post_url }} />

{% endfor %}

{% if current_spend_type == "NO_COST" %}
  {# Shared delete-confirmation modal; the trigger sets the confirm button's form-field name to the trait id #}
  <dialog id="trait-delete-modal" class="modal" aria-labelledby="trait-delete-heading">
    <div class="modal-box">
      <h3 id="trait-delete-heading" class="text-lg font-bold">Confirm Delete</h3>
      <p class="py-4">
        Are you sure you want to delete <strong id="trait-delete-name"></strong>? This cannot be undone.
      </p>
      <div class="modal-action">
        {# djlint:off #}
        <button type="button" class="btn btn-ghost"
                hx-on:click="this.closest('dialog').close()">Cancel</button>
        <button type="button" id="trait-delete-confirm" value="DELETE" class="btn btn-error"
                hx-post="{{ post_url }}"
                hx-on:click="this.closest('dialog').close()">Delete</button>
        {# djlint:on #}
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
{% endif %}

</shared.PageLayout>
