{# def
    character: Character,
    campaign: Campaign,
    active_section: str = "sheet",
    full_sheet: CharacterFullSheet | None = None,
    concept: CharacterConcept | None = None,
    assets: list[Asset] = [],
    dictionary_terms: list[DictionaryTerm] = [],
#}

<shared.PageLayout title={{ character.name }}>
<div class="flex flex-col gap-4">

  <shared.layout.CampaignChrome
      campaign={{ campaign }}
      active="characters"
      show_admin={{ is_admin() }} />

  <shared.layout.CharacterStrip character={{ character }} campaign={{ campaign }} />

  <h1 class="sr-only">{{ character.name_full }}</h1>

  <character_view.partials.CharacterContentCard
      character={{ character }}
      campaign={{ campaign }}
      active_section={{ active_section }}
      full_sheet={{ full_sheet }}
      concept={{ concept }}
      assets={{ assets }}
      dictionary_terms={{ dictionary_terms }} />
</div>

{% if can_edit_character(character) %}
  <character_view.components.CharacterDeleteModal character_id={{ character.id }} character_name={{ character.name_full }} />
{% endif %}
<shared.diceroll.DiceRollModal />
</shared.PageLayout>
