{#def
    character_id: str,
    character_name: str
#}

<dialog id="character-delete-modal" class="modal">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Confirm Delete</h3>
        <p class="py-4">
            Are you sure you want to delete <strong>{{ character_name }}</strong>? This cannot be undone.
        </p>
        <div class="modal-action">
            <shared.CommonButton variant="cancel" onclick="this.closest('dialog').close()">Cancel</shared.CommonButton>
            <button class="btn btn-error"
                    hx-delete="{{ url_for('character_view.delete', character_id=character_id) }}"
                    onclick="this.closest('dialog').close()">Delete</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
