{# def
    character_id: str,
    active_section: str = "sheet",
    oob: bool = False
#}

{% set sections = [('sheet', 'Sheet', '<path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" /><path d="M14 2v5a1 1 0 0 0 1 1h5" /><path d="M10 9H8" /><path d="M16 13H8" /><path d="M16 17H8" />'), ('info', 'Info', '<path d="M12 12V9a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3" /><path d="M16 20v-3a1 1 0 0 0-1-1h-2a1 1 0 0 0-1 1v3" /><path d="M20 22V2" /><path d="M4 12h16" /><path d="M4 20h16" /><path d="M4 2v20" /><path d="M4 4h16" />'), ('profile', 'Profile', '<path d="M2 21a8 8 0 0 1 10.821-7.487" /><path d="M21.378 16.626a1 1 0 0 0-3.004-3.004l-4.01 4.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z" /><circle cx="10" cy="8" r="5" />'), ('images', 'Images', '<rect width="18" height="18" x="3" y="3" rx="2" ry="2" /><circle cx="9" cy="9" r="2" /><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />'), ('stats', 'Stats', '<path d="M12 16v5" /><path d="M16 14v7" /><path d="M20 10v11" /><path d="m22 3-8.646 8.646a.5.5 0 0 1-.708 0L9.354 8.354a.5.5 0 0 0-.707 0L2 15" /><path d="M4 18v3" /><path d="M8 14v7" />')] %}

{# Mobile: button-based section switching #}
<div id="character-nav"
     {% if oob %}hx-swap-oob="true"{% endif %}
     class="my-3">
  <div class="lg:hidden mt-3 mb-1">
    {% for key, label, icon_paths in sections %}
      <button class="btn btn-sm {% if key == active_section %}btn-active{% endif %} mr-1 mb-1"
              hx-get="{{ url_for('character_view.character', character_id=character_id, section=key) }}"
              hx-target="#tab-content"
              hx-swap="innerHTML"
              hx-push-url="{{ url_for('character_view.character', character_id=character_id, section=key) }}">
        {{ label }}
      </button>
    {% endfor %}
  </div>

  {# Desktop: tabs with underline style #}
  <div role="tablist" class="tabs tabs-border tabs-lg hidden lg:flex">
    {% for key, label, icon_paths in sections %}
      <a role="tab"
         class="tab gap-1.5 {% if key == active_section %}tab-active{% endif %}"
         href="{{ url_for('character_view.character', character_id=character_id, section=key) }}"
         hx-get="{{ url_for('character_view.character', character_id=character_id, section=key) }}"
         hx-target="#tab-content"
         hx-swap="innerHTML"
         hx-push-url="true">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="16"
             height="16"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="2"
             stroke-linecap="round"
             stroke-linejoin="round">
          {{ icon_paths }}
        </svg>
        {{ label }}
      </a>
    {% endfor %}
  </div>
</div>
