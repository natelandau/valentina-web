{#def character, assets: list = [] #}

{% set images_editable = can_edit_character(character) %}

{% set delete_urls = {} %}
{% for asset in assets %}
  {% set _ = delete_urls.update({asset.id: url_for('character_view.image_delete', character_id=character.id, asset_id=asset.id)}) %}
{% endfor %}

<div id="images-content">
  {% if assets %}
    <shared.ImageCarousel assets={{ assets }}
                          delete_urls={{ delete_urls }}
                          editable={{ images_editable }}
                          carousel_id="character-image-carousel"
                          swap_target="images-content" />
  {% elif images_editable %}
    <p class="text-base-content/60 italic text-sm py-8 text-center">
      No images uploaded yet. Use <span class="font-medium">More → Upload Image</span> to add one.
    </p>
  {% else %}
    <p class="text-base-content/60 italic text-sm py-8 text-center">
      No images uploaded for this character.
    </p>
  {% endif %}
</div>
