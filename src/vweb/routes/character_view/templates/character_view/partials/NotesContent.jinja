{# def character #}

{% set editable_param = 'true' if can_edit_character(character) else 'false' %}

<shared.LazyFragment target_id="crud-notes"
                     url={{ url_for("character_view.character_notes", parent_id=character.id) ~ "?editable=" ~ editable_param }}
                     wrapper_class="flex justify-center py-8"
                     spinner_class="loading loading-spinner loading-lg" />
