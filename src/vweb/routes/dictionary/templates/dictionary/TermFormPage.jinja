{#def term = None #}
<shared.PageLayout title={{ ("Edit " ~ term.term if term else "Add Term") ~ " — Dictionary" }}>
  <div class="flex flex-col gap-4 max-w-2xl mx-auto">
    <a href="{{ url_for('dictionary.index') }}" class="link link-primary text-sm inline-flex items-center gap-1">
      <i class="fa-solid fa-arrow-left text-xs"></i> Back to Dictionary
    </a>
    <dictionary.partials.TermForm term={{ term }} />
  </div>
</shared.PageLayout>
