{#def
  term: DictionaryTerm | None = None,
  trait: Trait | None = None,
  subcategory: TraitSubcategory | None = None,
  errors: list = []
#}

{% set additional_data = {} %}

{% set game_versions = [] %}

{% set character_classes = [] %}

{% set sheet_section_name = None %}

{% set category_name = None %}

{% set trait_subcategory_name = None %}

{% set gift_attributes = {} %}

{% if trait %}

  {% set game_versions = trait.game_versions %}

  {% set character_classes = trait.character_classes %}

  {% set sheet_section_name = trait.sheet_section_name %}

  {% set category_name = trait.category_name %}

  {% set trait_subcategory_name = trait.subcategory_name %}

  {% set gift_attributes = trait.gift_attributes if trait.gift_attributes else {} %}

  {% do additional_data.update({"pool": trait.pool} if trait.pool else {}) %}

  {% do additional_data.update({"opposing_pool": trait.opposing_pool} if trait.opposing_pool else {}) %}

{% elif subcategory %}

  {% set sheet_section_name = subcategory.sheet_section_name %}

  {% set category_name = subcategory.category_name %}

  {% set game_versions = subcategory.game_versions %}

  {% set character_classes = subcategory.character_classes %}

  {% do additional_data.update({"pool": subcategory.pool} if subcategory.pool else {}) %}
  {% do additional_data.update({"hunter_edge_type": subcategory.hunter_edge_type | title} if subcategory.hunter_edge_type else {}) %}

{% endif %}

{% if term is none %}
  <div class="flex items-center justify-center h-full text-base-content/40 text-sm">
    Select a term to view its definition
  </div>
{% else %}
  <div class="p-6">
    <a href="{{ url_for('dictionary.index') }}"
       class="lg:hidden link link-primary text-sm inline-flex items-center gap-1 mb-4">
      <i class="fa-solid fa-arrow-left text-xs"></i> Back to Dictionary
    </a>
    {% if errors %}
      <div class="alert alert-error mb-4" role="alert">
        <i class="fa-solid fa-circle-exclamation"></i>
        <ul class="list-disc list-inside text-sm">
          {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="flex items-start justify-between mb-1">
      <div>
        {% if term.source_type is not none %}
          <div class="badge badge-secondary badge-soft badge-sm mb-2">
            {{ term.source_type | replace('_', ' ') | title }}
          </div>

          {% for gv in game_versions %}
            <div class="badge badge-secondary badge-soft badge-sm mb-2">
              {{ gv | title }}
            </div>
          {% endfor %}

          {% for class in character_classes %}
            <div class="badge badge-secondary badge-soft badge-sm mb-2">
              {{ class | title }}
            </div>
          {% endfor %}

        {% endif %}
        <h2 class="text-2xl font-bold mb-2">{{ term.term | title }}</h2>
        {% if sheet_section_name and category_name %}
          <p class="text-sm text-base-content/50 mb-2">
            {{ sheet_section_name | title }} > {{ category_name | title }}
            {% if trait_subcategory_name %}
              > {{ trait_subcategory_name | title }}
            {% endif %}
          </p>
        {% endif %}

      </div>
      <div class="flex gap-1">

        {% set edit_attrs = 'hx-get="' ~ url_for("dictionary.term_form_edit", term_id=term.id) ~ '" hx-target="#term-detail" hx-swap="innerHTML"' %}

        {% set tooltip_text = "Global terms cannot be edited" if term.source_type is not none else "" %}

        <shared.CommonButton variant="edit" tooltip_text={{ tooltip_text }} disabled={{ term.source_type is not none }} extra_attrs={{ edit_attrs }}>Edit</shared.CommonButton>
        {# djlint:off #}
          <shared.CommonButton variant="delete" disabled={{ term.source_type is not none }} btn_type="button" hx-on:click="document.getElementById('delete-term-modal').showModal()" tooltip_text={{ tooltip_text }}>Delete</shared.CommonButton>
        {# djlint:on #}
      </div>
    </div>

    {% if term.synonyms %}
      <div class="flex flex-wrap gap-1 mb-4">
        <span class="text-base-content/50 text-sm">Synonyms:</span>
        {% for syn in term.synonyms %}
          <div class="badge badge-info badge-soft badge-sm">{{ syn }}</div>
        {% endfor %}
      </div>
    {% endif %}

    {% if term.definition %}
      <div class="prose prose-md max-w-none">
        {{ term.definition | from_markdown | link_terms(link_type="html", excludes=[term.term] + term.synonyms) }}

        {% for key, value in additional_data.items() %}
          <p>
            <span class="font-bold">{{ key | replace('_', ' ') | title }}:</span> {{ value | from_markdown_no_p }}
          </p>
        {% endfor %}

        {% if gift_attributes %}
          <h3 class="text-lg font-bold mb-2">Gift Attributes</h3>
          <ul class="list-disc list-inside text-sm">
            {% for k,v in gift_attributes if k not in ["tribe_id", "auspice_id"] %}
              <li>
                <span class="font-bold">{{ k | replace('_', ' ') | title }}:</span> {{ v }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      </div>
    {% endif %}

    {% if term.link %}
      <div class="border-t border-base-300 mt-4 pt-3">
        <a href="{{ term.link }}"
           target="_blank"
           rel="noopener"
           class="link link-primary inline-flex items-center gap-1">
          Open external reference <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
        </a>
      </div>
    {% endif %}

    {% if term.source_type is none %}
      <dialog id="delete-term-modal" class="modal">
        <div class="modal-box">
          <h3 class="text-lg font-bold">Delete "{{ term.term }}"?</h3>
          <p class="py-4">This action cannot be undone.</p>
          <div class="modal-action">
            <button type="button" class="btn btn-ghost"
                    hx-on:click="this.closest('dialog').close()">Cancel</button>

            {% set del_attrs = 'hx-delete="' ~ url_for("dictionary.term_delete", term_id=term.id) ~ '" hx-target="#term-detail" hx-swap="innerHTML"' %}

            <shared.CommonButton variant="delete" extra_attrs={{ del_attrs }}>Delete</shared.CommonButton>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop">
          <button>close</button>
        </form>
      </dialog>
    {% endif %}
  </div>
{% endif %}
