{# def
    campaign = None,
    user_characters: list = [],
    other_characters: list = [],
    books: list = [],
    campaign_statistics = None,
    campaign_experience = None,
    user: User = None,
#}

<shared.PageLayout title="Home">
{% if campaign is none %}
  <div class="flex flex-col items-center justify-center py-16">
    <h2 class="text-2xl font-bold mb-4">No campaigns exist yet.</h2>
    <p class="text-base-content/60">
      <a class="link link-primary"
         x-data @click="document.getElementById('campaign-create-modal').showModal()">Create one.</a>
    </p>
  </div>
{% else %}

  <div class="flex flex-col gap-6">

    {# Campaign Header Bar #}

    {% set header_actions %}

      {% if can_manage_campaign() %}
        <details class="dropdown dropdown-end">
          <summary class="btn btn-sm btn-ghost">
            <i class="fa-solid fa-bars"></i>
            <span class="inline">More</span>
          </summary>
          <ul class="menu dropdown-content bg-base-100 rounded-box z-10 w-56 p-2 shadow-md">
            <li>
              <button hx-get="{{ url_for('campaign.edit_form', campaign_id=campaign.id) }}"
                      hx-target="#campaign-create-modal .modal-box"
                      hx-swap="innerHTML"
                      x-data @click="document.getElementById('campaign-create-modal').showModal()">
                <i class="fa-regular fa-pen-to-square"></i> Edit Campaign
              </button>
            </li>
            <li class="border-t border-base-300 mt-1 pt-1">
              <button class="text-error hover:bg-error/10"
                      x-data @click="document.getElementById('campaign-delete-modal').showModal()">
                <i class="fa-solid fa-trash-can"></i> Delete Campaign
              </button>
            </li>
          </ul>
        </details>
      {% endif %}
    {% endset %}

    <shared.PageHeader title={{ campaign.name }} before_text="Campaign" actions={{ header_actions }}>
    <div class="flex items-center gap-2 flex-wrap mt-2">
      {% if campaign.danger is not none %}

        {% set danger_color = "badge-neutral" if campaign.danger < 2 else "badge-warning" if campaign.danger is in [2, 3] else "badge-error" %}

        <span class="badge {{ danger_color }} badge-sm text-semibold">Danger {{ campaign.danger }}</span>
      {% endif %}
      {% if campaign.desperation is not none %}

        {% set desperation_color = "badge-neutral" if campaign.desperation < 2 else "badge-warning" if campaign.desperation is in [2, 3] else "badge-error" %}

        <span class="badge {{ desperation_color }} badge-sm text-semibold">Desperation {{ campaign.desperation }}</span>
      {% endif %}
    </div>
    </shared.PageHeader>

    {# Content Cards Grid #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

      {# Your Characters card #}
      <shared.cards.CharacterListCard title="Your Characters" characters={{ user_characters }} show_type={{ is_storyteller() }} show_add_button={{ true }} add_url={{ url_for('character_create.selection_page', campaign_id=campaign.id) }} empty_message="No characters in this campaign" pagination={{ 5 }} />

      <index.components.UserListCard users={{ g.global_context.users }} pagination={{ 3 }} campaign_id={{ campaign.id }} />

      {# Other Players' Characters card #}
      <shared.cards.CharacterListCard title="Other Players' Characters" characters={{ other_characters }} show_type={{ is_storyteller() }} empty_message="No other players' characters" pagination={{ 5 }} link_user_profile={{ true }} />

      {# Books card #}
      {% set book_urls = {} %}
      {% for book in books %}
        {% set _ = book_urls.update({book.id: url_for('book_view.book_detail', campaign_id=book.campaign_id, book_id=book.id)}) %}
      {% endfor %}

      <shared.cards.NumberedListCard title={{ campaign.name ~ " Books" }} items={{ books }} pagination={{ 5 }} item_urls={{ book_urls }} empty_message="No books in this campaign" />
      {# /Books card #}

      {# Campaign Statistics #}
      {% if campaign_statistics %}
        <shared.cards.StatisticsCard statistics={{ campaign_statistics }} col_span={{ 2 }} />
      {% endif %}
      {# Campaign Description #}
      {% if campaign.description %}
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body">
            <h2 class="card-title mb-2">Campaign Description</h2>
            <div class="prose prose-sm imax-w-none">
              {{ campaign.description | from_markdown }}
            </div>
          </div>
        </div>
      {% endif %}

    </div>
    {# /Content Cards Grid #}
  </div>
  {% if can_manage_campaign() %}
    <index.components.CampaignDeleteModal campaign_id={{ campaign.id }} campaign_name={{ campaign.name }} />
  {% endif %}
  <shared.diceroll.DiceRollModal />
{% endif %}
</shared.PageLayout>
