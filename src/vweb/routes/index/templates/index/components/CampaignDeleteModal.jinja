{#def
    campaign_id: str,
    campaign_name: str
#}

<dialog id="campaign-delete-modal" class="modal">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Confirm Delete</h3>
        <p class="py-4">
            Are you sure you want to delete <strong>{{ campaign_name }}</strong>? This cannot be undone.
        </p>
        <div class="modal-action">
            <shared.CommonButton variant="cancel" onclick="this.closest('dialog').close()">Cancel</shared.CommonButton>
            <button class="btn btn-error"
                    hx-delete="{{ url_for('campaign.delete', campaign_id=campaign_id) }}"
                    onclick="this.closest('dialog').close()">Delete</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
