{#def
    user,
    user_characters: list = [],
    statistics = None,
    lifetime_xp: int = 0,
    lifetime_cool_points: int = 0,
    experience_rows: list = [],
    character_count: int = 0,
#}

{% set is_own_profile = is_self(user.id) %}

{% set display_name = (user.name_first ~ " " ~ user.name_last) if user.name_first and user.name_last else user.username %}

{% set edit_btn %}

  {% if is_own_profile %}

    {% set edit_attrs = 'hx-get="' ~ url_for('profile.edit_profile', user_id=user.id) ~ '" hx-target="#profile-edit-form" hx-swap="innerHTML"' %}

    <shared.CommonButton variant="edit" extra_class="btn-sm" extra_attrs={{ edit_attrs }}>
    <i class="fa-regular fa-pen-to-square"></i>
    Edit Profile
    </shared.CommonButton>
  {% endif %}
{% endset %}

{% set avatar_url = (user.discord_profile.avatar_url if user.discord_profile and user.discord_profile.avatar_url else (user.github_profile.avatar_url if user.github_profile and user.github_profile.avatar_url else (user.google_profile.avatar_url if user.google_profile and user.google_profile.avatar_url else ""))) %}
{% if avatar_url %}
  {% set avatar_html = '<div class="avatar w-16"><img alt="' ~ user.username ~ '" src="' ~ avatar_url ~ '" class="rounded-full" /></div>' %}
{% else %}
  {% set initials = (user.name_first or user.username)[0] | upper ~ (user.name_last[0] | upper if user.name_last else "") %}
  {% set avatar_html = '<div class="avatar avatar-placeholder"><div class="bg-neutral text-neutral-content w-16 rounded-full"><span>' ~ initials ~ '</span></div></div>' %}
{% endif %}

<shared.PageLayout title={{ user.username }}>
    <shared.PageHeader title={{ user.username }} actions={{ edit_btn }} back_url={{ url_for('index.index') }} back_text="Back Home" icon={{ avatar_html }}>
    <div class="flex flex-wrap items-center gap-2 mt-1 text-sm opacity-70">
      {% if user.name_first and user.name_last %}
        <span>{{ user.name_first }} {{ user.name_last }}</span>
        <span>&middot;</span>
      {% endif %}
      <span class="badge badge-sm badge-outline">{{ user.role }}</span>
      <span>&middot;</span>
      <span>Joined {{ user.date_created | humanize_date }}</span>
      <span>&middot;</span>
      <span>{{ character_count }} character{{ "s" if character_count != 1 else "" }}</span>
    </div>
    </shared.PageHeader>

<!-- Edit form target (empty until Edit Profile clicked) -->
<div id="profile-edit-form" class="mt-4"></div>

<!-- Experience & Statistics cards -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mt-6">
  <div id="experience-card" class="h-full">
    <profile.components.ExperienceCard user_id={{ user.id }} lifetime_xp={{ lifetime_xp }} lifetime_cool_points={{ lifetime_cool_points }} experience_rows={{ experience_rows }} />
  </div>

  {% if statistics and statistics.total_rolls > 0 %}
    <shared.cards.StatisticsCard statistics={{ statistics }} title={{ user.username ~ "'s Roll Statistics" }} />
  {% else %}
    <div class="card surface-card h-full">
      <div class="card-body">
        <h2 class="card-title">{{ user.username }}'s Roll Statistics</h2>
        <p class="text-base-content/60">No rolls recorded yet</p>
      </div>
    </div>
  {% endif %}
</div>

<!-- Quickrolls CRUD table -->
<div class="mt-6">

  {% set editable_param = "true" if is_own_profile else "false" %}

  <div class="card surface-card">
    <div class="card-body">
      <div id="crud-quickrolls"
           hx-get="{{ url_for("profile.quickrolls", user_id=user.id) }}?editable={{ editable_param }}"
           hx-trigger="load"
           hx-swap="innerHTML">
        <span class="loading loading-spinner loading-md"></span>
      </div>
    </div>
  </div>
</div>

<!-- Characters list -->
<div class="mt-6">
  <shared.cards.CharacterListCard title="Characters" characters={{ user_characters }} show_campaign={{ true }} show_type={{ true }} empty_message="No characters yet" />
</div>
<shared.diceroll.DiceRollModal />
</shared.PageLayout>
