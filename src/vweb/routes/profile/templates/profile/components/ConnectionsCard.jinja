{#def user #}
{# Shown only on your own profile: connect or disconnect login providers.
   A provider can only be disconnected when more than one is linked; the API
   refuses to remove the last sign-in method. #}
{% set providers = [
  ("discord", "Discord", "fa-discord", user.discord_profile),
  ("github", "GitHub", "fa-github", user.github_profile),
  ("google", "Google", "fa-google", user.google_profile),
  ("apple", "Apple", "fa-apple", user.apple_profile),
] %}
{% set linked_count = providers | selectattr(3) | list | length %}
<div id="connections-card" class="card surface-card">
  <div class="card-body">
    <h2 class="card-title">Account Connections</h2>
    <p class="text-sm opacity-70">Link other sign-in providers to this account.</p>
    <ul class="space-y-2 mt-2">
      {% for key, label, icon, profile in providers %}
        <li class="flex items-center justify-between gap-2">
          <span class="inline-flex items-center gap-2">
            <i class="fa-brands {{ icon }}" aria-hidden="true"></i>
            {{ label }}
          </span>
          {% if profile %}
            <span class="inline-flex items-center gap-2">
              <span class="inline-flex items-center gap-1 text-sm text-success"><i class="fa-solid fa-check" aria-hidden="true"></i>Connected</span>
              {% if linked_count > 1 %}
                {% set disconnect_attrs = 'hx-post="' ~ url_for('auth.unlink_identity', provider=key) ~ '" hx-target="#connections-card" hx-swap="outerHTML" hx-confirm="Disconnect ' ~ label ~ '? This removes it as a way to sign in to your account."' %}
                <shared.CommonButton variant="delete" btn_type="button" extra_class="btn-sm" extra_attrs={{ disconnect_attrs }}>Disconnect</shared.CommonButton>
              {% endif %}
            </span>
          {% else %}
            <shared.CommonButton variant="add" extra_class="btn-sm" href={{ url_for('auth.link_identity', provider=key) }}><i class="fa-solid fa-plus"></i>Connect</shared.CommonButton>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>
