{#def user #}
{# Shown only on your own profile: connect or disconnect login providers.
   A provider can only be disconnected when more than one is linked; the API
   refuses to remove the last sign-in method. #}
{% set providers = [
  ("discord", "Discord", "fa-discord", user.discord_profile),
  ("github", "GitHub", "fa-github", user.github_profile),
  ("google", "Google", "fa-google", user.google_profile),
  ("apple", "Apple", "fa-apple", user.apple_profile),
] %}
{% set linked_count = providers | selectattr(3) | list | length %}
<div id="connections-card" class="card surface-card">
  <div class="card-body">
    <h2 class="card-title">Connections</h2>
    <p class="text-sm opacity-70">Link other sign-in providers to this account.</p>
    <ul class="space-y-2 mt-2">
      {% for key, label, icon, profile in providers %}
        <li class="flex items-center justify-between gap-2">
          <span class="inline-flex items-center gap-2">
            <i class="fa-brands {{ icon }}" aria-hidden="true"></i>
            {{ label }}
          </span>
          {% if profile %}
            <span class="inline-flex items-center gap-2">
              <span class="badge badge-success badge-outline">Connected</span>
              {% if linked_count > 1 %}
                {# djlint:off #}
                <button type="button" class="btn btn-sm btn-ghost text-error"
                        hx-post="{{ url_for('auth.unlink_identity', provider=key) }}"
                        hx-target="#connections-card" hx-swap="outerHTML"
                        hx-confirm="Disconnect {{ label }}? This removes it as a way to sign in to your account.">Disconnect</button>
                {# djlint:on #}
              {% endif %}
            </span>
          {% else %}
            {# djlint:off #}
            <a href="{{ url_for('auth.link_identity', provider=key) }}" class="btn btn-sm btn-outline">Connect</a>
            {# djlint:on #}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>
