{#def
    user_id: str = "",
    experience_rows: list = [],
#}

{% set show_grant = can_grant_experience(user_id) %}

{% if experience_rows %}
  {# Desktop: standard table (hidden below md) #}
  <div class="hidden md:block overflow-x-auto mt-4">
    <table class="table table">
      <thead>
        <tr>
          <th>Campaign</th>
          <th class="text-right">Available XP</th>
          <th class="text-right">Total XP</th>
          <th class="text-right">Cool Points</th>
          {% if show_grant %}<th class="text-right"></th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for row in experience_rows %}
          <tr>
            <td class="font-semibold">{{ row.campaign_name }}</td>
            <td class="text-right font-mono">{{ row.xp_current }}</td>
            <td class="text-right font-mono">{{ row.xp_total }}</td>
            <td class="text-right font-mono">{{ row.cool_points }}</td>
            {% if show_grant %}
              <td class="text-right">

                {% set exp_attrs = 'hx-get="' ~ url_for('profile.experience_form', user_id=user_id, campaign_id=row.campaign_id) ~ '" hx-target="#experience-card" hx-swap="innerHTML"' %}

                <shared.CommonButton variant="add" extra_class="btn-xs" extra_attrs={{ exp_attrs }}><i class="fa-solid fa-plus"></i> Experience</shared.CommonButton>
              </td>
            {% endif %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# Mobile: card layout (hidden at md+) #}
  <div class="flex flex-col gap-3 md:hidden mt-4">
    {% for row in experience_rows %}
      <div class="card card-border bg-base-200/50">
        <div class="card-body p-4 gap-1">
          <h3 class="card-title text-lg">{{ row.campaign_name }}</h3>
          <p class="text-base-content/70">
            <span class="font-medium text-base-content/50">Available XP:</span>
            <span class="font-mono">{{ row.xp_current }}</span>
          </p>
          <p class="text-base-content/70">
            <span class="font-medium text-base-content/50">Total XP:</span>
            <span class="font-mono">{{ row.xp_total }}</span>
          </p>
          <p class="text-base-content/70">
            <span class="font-medium text-base-content/50">Cool Points:</span>
            <span class="font-mono">{{ row.cool_points }}</span>
          </p>
          {% if show_grant %}

            {% set exp_attrs = 'hx-get="' ~ url_for('profile.experience_form', user_id=user_id, campaign_id=row.campaign_id) ~ '" hx-target="#experience-card" hx-swap="innerHTML"' %}

            <div class="card-actions justify-end mt-2">
              <shared.CommonButton variant="add" extra_class="btn-xs" extra_attrs={{ exp_attrs }}><i class="fa-solid fa-plus"></i> Experience</shared.CommonButton>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
{% else %}
  <p class="text-base-content/60 mt-2">No campaign experience yet</p>
{% endif %}
