{#def
    user,
    form_data: dict = {},
    errors: list = [],
#}

<div class="card surface-card">
  <div class="card-body">
    <h2 class="card-title">Edit Profile</h2>

    {% if errors %}
      <div class="alert alert-error">
        <ul>
          {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
      </div>
    {% endif %}

    <form hx-post="{{ url_for('profile.profile', user_id=user.id) }}"
          hx-target="#profile-edit-form"
          hx-swap="innerHTML"
          hx-encoding="multipart/form-data">
      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}" />

      {# djlint:off #}
      {% set resolved_avatar = user_avatar_url(user) %}
      <fieldset class="fieldset"
                data-avatar="{{ resolved_avatar or '' }}"
                x-data="{ preview: $el.dataset.avatar }">
        <legend class="fieldset-legend">Avatar</legend>
        <div class="flex items-center gap-5">
          <button type="button"
                  class="group relative block shrink-0 rounded-full focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 focus-visible:outline-none"
                  @click="$refs.avatarInput.click()"
                  aria-label="Choose a new avatar">
            <div class="avatar" :class="{ 'avatar-placeholder': !preview }">
              <div class="bg-neutral text-neutral-content w-20 rounded-full ring ring-base-300 ring-offset-base-100 ring-offset-2 transition-colors duration-200 group-hover:ring-primary">
                <template x-if="preview">
                  <img :src="preview" alt="{{ user.username }}" class="rounded-full" />
                </template>
                <template x-if="!preview">
                  <span class="text-xl">{{ (user.name_first or user.username)[0] | upper }}</span>
                </template>
              </div>
            </div>
            <span class="pointer-events-none absolute inset-0 flex items-center justify-center rounded-full bg-base-content/55 text-base-100 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
              <i class="fa-solid fa-camera text-lg"></i>
            </span>
          </button>
          <div class="flex flex-col gap-1.5">
            <input type="file"
                   name="avatar"
                   x-ref="avatarInput"
                   accept="image/png,image/jpeg,image/webp,image/gif"
                   class="file-input file-input-sm file-input-ghost w-full max-w-xs"
                   @change="preview = $event.target.files.length ? URL.createObjectURL($event.target.files[0]) : preview" />
            <span class="text-xs opacity-60">PNG, JPEG, WebP or GIF &middot; max {{ MAX_AVATAR_SIZE // (1024 * 1024) }} MB</span>
            {% if has_custom_avatar(user) %}
              <label class="label w-fit cursor-pointer gap-2 text-xs opacity-80 transition-opacity hover:opacity-100">
                <input type="checkbox" name="remove_avatar" class="checkbox checkbox-xs checkbox-error" />
                <span>Remove custom avatar</span>
              </label>
            {% endif %}
          </div>
        </div>
      </fieldset>
      {# djlint:on #}

      <fieldset class="fieldset">
        <legend class="fieldset-legend">First Name</legend>
        <input type="text"
               name="name_first"
               class="input input-bordered w-full"
               value="{{ form_data.get('name_first', '') if form_data else (user.name_first or '') }}" />
      </fieldset>

      <fieldset class="fieldset">
        <legend class="fieldset-legend">Last Name</legend>
        <input type="text"
               name="name_last"
               class="input input-bordered w-full"
               value="{{ form_data.get('name_last', '') if form_data else (user.name_last or '') }}" />
      </fieldset>

      <fieldset class="fieldset">
        <legend class="fieldset-legend">Username *</legend>
        <input type="text"
               name="username"
               class="input input-bordered w-full"
               required
               value="{{ form_data.get('username', '') if form_data else user.username }}" />
      </fieldset>

      <fieldset class="fieldset">
        <legend class="fieldset-legend">Email *</legend>
        <input type="email"
               name="email"
               class="input input-bordered w-full"
               required
               value="{{ form_data.get('email', '') if form_data else user.email }}" />
      </fieldset>

      <div class="flex gap-2 mt-4">
        <shared.CommonButton variant="submit" extra_class="btn-sm">Save</shared.CommonButton>
        <shared.CommonButton variant="cancel" extra_class="btn-sm" hx-on:click="document.getElementById('profile-edit-form').innerHTML = ''">
        Cancel
        </shared.CommonButton>
      </div>
    </form>
  </div>
</div>
