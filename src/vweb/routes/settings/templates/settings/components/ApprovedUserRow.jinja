{#def user #}
<div id="user-{{ user.id }}" class="flex items-center gap-3 py-2 border-b border-base-300">
  <shared.UserAvatar user={{ user }} size="w-10" />
  <div class="grow">
    <div class="font-medium">{{ user.name_first }} {{ user.name_last or "" }}</div>
    <div class="text-sm text-base-content/70">{{ user.email }}</div>
  </div>
  <select name="role"
          class="select select-sm"
          hx-post="{{ url_for('settings.change_role', user_id=user.id) }}"
          hx-target="#user-{{ user.id }}"
          hx-swap="outerHTML"
          hx-include="this">
    <option value="PLAYER" {% if user.role == "PLAYER" %}selected{% endif %}>Player</option>
    <option value="STORYTELLER" {% if user.role == "STORYTELLER" %}selected{% endif %}>Storyteller</option>
    <option value="ADMIN" {% if user.role == "ADMIN" %}selected{% endif %}>Admin</option>
  </select>
</div>
