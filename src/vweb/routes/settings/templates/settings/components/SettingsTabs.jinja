{#def active="company", pending_count=0 #}
<div role="tablist" class="tabs tabs-border mb-4">
  <a role="tab"
     class="tab {% if active == 'company' %}tab-active{% endif %}"
     href="{{ url_for('settings.settings') }}">Company</a>
  <a role="tab"
     class="tab {% if active == 'users' %}tab-active{% endif %}"
     href="{{ url_for('settings.users') }}">
    Users
    {% if pending_count > 0 %}
      <span class="badge badge-sm badge-warning ml-2">{{ pending_count }}</span>
    {% endif %}
  </a>
</div>
