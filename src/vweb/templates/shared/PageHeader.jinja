{#def
    title: str = "",
    before_text: str = "",
    after_text: str = "",
    actions: str = "",
    back_url: str = "",
    back_text: str = "",
    icon: str = ""
#}

<div class="bg-base-200 rounded-box p-3 sm:p-4">
  {% if back_url and back_text %}
    <a href="{{ back_url }}" class="link link-primary text-sm inline-flex items-center gap-1 mb-1">
      <i class="fa-solid fa-chevron-left text-xs"></i> {{ back_text }}
    </a>
  {% endif %}
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    {% if icon %}
      <div class="shrink-0">{{ icon }}</div>
    {% endif %}
    <div class="min-w-0 flex-1">
      <div class="flex flex-col sm:flex-row sm:items-baseline">
        {% if before_text %}
          <div class="text-2xl sm:text-3xl font-thin opacity-50 tabular-nums text-nowrap sm:pr-2">
            {{ before_text }}
          </div>
        {% endif %}
        <h1 class="text-3xl font-bold">{{ title }}</h1>
        {% if after_text %}
          <div class="text-2xl sm:text-3xl font-thin opacity-50 tabular-nums text-nowrap sm:pl-2">
            {{ after_text }}
          </div>
        {% endif %}
      </div>
      {{ content }}
    </div>
    {% if actions %}
      <div class="flex flex-wrap items-center gap-1.5 shrink-0">
        {{ actions }}
      </div>
    {% endif %}
  </div>
</div>
