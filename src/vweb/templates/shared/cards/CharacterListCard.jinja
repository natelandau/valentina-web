{# Character list lazy-load wrapper.
   Scope is exactly one of: campaign_id (+ bucket = mine|others|all) or user_id.
   card_id must be unique per page when multiple character cards coexist; it is
   interpolated into DOM ids and hx-target selectors. #}
{#def
    title: str,
    campaign_id: str = "",
    bucket: str = "all",
    user_id: str = "",
    show_type: bool = False,
    show_campaign: bool = False,
    link_user_profile: bool = False,
    show_add_button: bool = False,
    show_filters: bool = True,
    page_size: int = 0,
    col_span: int = 0,
    card_id: str = "characterlist",
    empty_message: str = "No characters found",
#}

{% set url = build_fragment_url(
    "shared_cards.character_list",
    campaign_id=campaign_id,
    bucket=bucket,
    user_id=user_id,
    title=title,
    show_type="true" if show_type else "",
    show_campaign="true" if show_campaign else "",
    link_user_profile="true" if link_user_profile else "",
    show_add_button="true" if show_add_button else "",
    show_filters="true" if show_filters else "false",
    page_size=page_size,
    col_span=col_span,
    card_id=card_id,
    empty_message=empty_message,
) %}

{% set grid_col_span = "lg:col-span-" ~ col_span if col_span > 0 else "" %}

<div hx-get="{{ url }}" hx-trigger="load" hx-swap="outerHTML"{% if grid_col_span %} class="{{ grid_col_span }}"{% endif %}>
  <div class="card surface-card{% if grid_col_span %} {{ grid_col_span }}{% endif %}">
    <div class="card-body">
      <div class="flex items-center justify-between">
        <h2 class="card-title">{{ title }}</h2>
        {% if show_add_button and campaign_id %}
          <shared.CommonButton variant="add" extra_class="btn-sm" href={{ url_for('character_create.selection_page', campaign_id=campaign_id) }}>+ Add New</shared.CommonButton>
        {% endif %}
      </div>
      <div class="flex items-center justify-center py-12">
        <span class="loading loading-spinner loading-md"></span>
      </div>
    </div>
  </div>
</div>
