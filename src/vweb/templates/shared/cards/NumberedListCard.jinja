{#def
    title: str,
    items: list,
    item_urls: dict,
    card_id: str = "",
    empty_message: str = "No items found",
    add_button_label: str = "",
    add_button_attrs: str = "",
    editable: bool = False,
    col_span: int = 0,
    pagination: int = 0,
    oob: bool = False,
#}

{% set grid_col_span = "col-span-" ~ col_span if col_span > 0 else "" %}

<div {% if card_id %}id="{{ card_id }}"{% endif %}
     {% if oob %}hx-swap-oob="true"{% endif %}
     class="card surface-card {{ grid_col_span }}">
  <div class="card-body">
    <div class="flex items-center justify-between">
      <h2 class="card-title">{{ title }}</h2>
      {% if editable and add_button_label %}
        <shared.CommonButton variant="add" extra_class="btn-sm" extra_attrs={{ add_button_attrs }}>
        <i class="fa-solid fa-plus"></i> {{ add_button_label }}
        </shared.CommonButton>
      {% endif %}
    </div>

    {% if items %}
      {% if pagination > 0 %}
        <div x-data="{ currentPage: 1, pageSize: {{ pagination }}, totalItems: {{ items|length }}, get totalPages() { return Math.ceil(this.totalItems / this.pageSize) }, listHeight: 0 }"
             x-init="$nextTick(() => { listHeight = $refs.list.offsetHeight })">
        {% endif %}

        <ul class="list bg-base-100 rounded-box shadow-md"
            {% if pagination > 0 %}x-ref="list" :style="listHeight ? 'min-height:' + listHeight + 'px' : ''"{% endif %}>
          {% for item in items | sort(attribute="number") %}

            {% set item_url = item_urls.get(item.id, "#") %}

            <li class="list-row hover:bg-neutral/80 hover:text-neutral-content transition-colors" {% if pagination > 0 %}x-cloak x-show="({{ loop.index0 }} >= (currentPage - 1) * pageSize) && ({{ loop.index0 }} < currentPage * pageSize)"
            {% endif %}
            >
            <div class="text-4xl font-thin opacity-30 tabular-nums text-nowrap">
              {{ "%02d" | format(item.number) }}
            </div>
            <div class="list-col-grow">
              <a href="{{ item_url }}" class="block">
                <div class="font-semibold tracking-wide">{{ item.name }}</div>
                {% if item.description %}
                  <p class="text-xs opacity-60 list-col-wrap">
                    {{ item.description | truncate(120) }}
                  </p>
                {% endif %}
              </a>
            </div>
            <div>
              <a href="{{ item_url }}" class="btn btn-square btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="24"
                     height="24"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     class="lucide lucide-square-arrow-up-right-icon lucide-square-arrow-up-right">
                  <rect width="18" height="18" x="3" y="3" rx="2" />
                  <path d="M8 8h8v8" />
                  <path d="m8 16 8-8" />
                </svg>
              </a>
            </div>
          </li>
        {% endfor %}
      </ul>

      {% if pagination > 0 %}
        <shared.cards.Pagination />
      </div>
    {% endif %}

  {% else %}
    <p class="text-base-content/60 text-sm">{{ empty_message }}</p>
  {% endif %}
</div>
</div>
