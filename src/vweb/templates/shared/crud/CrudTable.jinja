{#def
    table_type_name: str,
    table_type_item_name: str,
    columns: tuple,
    fields: tuple,
    markdown_fields: tuple = (),
    sortable_fields: tuple = (),
    items: list,
    parent_id: str,
    table_base_url: str,
    form_base_url: str,
    table_target_id: str,
    sort_field: str = "",
    sort_dir: str = "asc",
    editable: bool = True,
    extra_params: str = "",
    page_size: int = 0,
#}

<div class="flex justify-between items-center mb-4">
  <h2 class="card-title">{{ table_type_name }}</h2>
  {% if editable %}
    <shared.CommonButton variant="add" extra_class="btn-sm"
                  hx-get={{ form_base_url ~ "?parent_id=" ~ parent_id ~ extra_params }}
                  hx-target={{ "#" ~ table_target_id }}
                  hx-swap="innerHTML">
      <i class="fa-solid fa-plus"></i> Add {{ table_type_item_name }}
    </shared.CommonButton>
  {% endif %}
</div>

{% if items %}
  {% if page_size > 0 %}
    <div x-data="{ currentPage: 1, pageSize: {{ page_size }}, totalItems: {{ items|length }}, get totalPages() { return Math.ceil(this.totalItems / this.pageSize) } }">
  {% endif %}
  {# Desktop: standard table (hidden below md) #}
  <div class="hidden md:block">
    <table class="table table-zebra">
      <thead>
        <tr>
          {% for col in columns %}

            {% set field = fields[loop.index0] %}

            {% if field in sortable_fields %}
              {% if field == sort_field %}

                {% set next_sort = "-" ~ field if sort_dir == "asc" else field %}

              {% else %}

                {% set next_sort = field %}

              {% endif %}
              <th>
                <a class="cursor-pointer select-none inline-flex items-center gap-1"
                   hx-get="{{ table_base_url }}?parent_id={{ parent_id }}&sort={{ next_sort }}{{ extra_params }}"
                   hx-target="#{{ table_target_id }}"
                   hx-swap="innerHTML">
                  {{ col }}
                  {% if field == sort_field %}
                    {% if sort_dir == "asc" %}
                      <i class="fa-solid fa-sort-up"></i>
                    {% else %}
                      <i class="fa-solid fa-sort-down"></i>
                    {% endif %}
                  {% endif %}
                </a>
              </th>
            {% else %}
              <th>{{ col }}</th>
            {% endif %}
          {% endfor %}
          {% if editable %}<th class="w-24"></th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for item in items %}
          <tr {% if page_size > 0 %}x-cloak x-show="({{ loop.index0 }} >= (currentPage - 1) * pageSize) && ({{ loop.index0 }} < currentPage * pageSize)"{% endif %}>
            {% for field in fields %}
              {% if loop.first %}
                <th class="text-md">{{ item[field] | default("", true) }}</th>
              {% elif field in markdown_fields %}
                <td class="prose prose-sm">{{ item[field] | default("", true) | from_markdown }}</td>
              {% else %}
                <td>{{ item[field] | default("", true) }}</td>
              {% endif %}
            {% endfor %}
            {% if editable %}
              <td class="flex gap-1 justify-end">
                <shared.CommonButton variant="edit" extra_class="btn-xs"
                              hx-get={{ form_base_url ~ "/" ~ item.id ~ "?parent_id=" ~ parent_id ~ extra_params }}
                              hx-target={{ "#" ~ table_target_id }}
                              hx-swap="innerHTML"
                              title="Edit">
                  <i class="fa-regular fa-pen-to-square"></i>
                  Edit
                </shared.CommonButton>

                {% set delete_url = table_base_url ~ "/" ~ item.id ~ "?parent_id=" ~ parent_id ~ extra_params %}
                {# djlint:off #}
                <button type="button" class="btn btn-error btn-soft btn-xs" title="Delete"
                        hx-on:click="var btn = document.getElementById('delete-confirm-btn-{{ table_target_id }}'); btn.setAttribute('hx-delete', '{{ delete_url }}'); htmx.process(btn); document.getElementById('delete-modal-{{ table_target_id }}').showModal()">
                  <i class="fa-solid fa-trash-can"></i>
                  Delete
                </button>
                {# djlint:on #}
              </td>
            {% endif %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <shared.crud.CrudTableMobile columns={{ columns }}
                               fields={{ fields }}
                               markdown_fields={{ markdown_fields }}
                               items={{ items }}
                               parent_id={{ parent_id }}
                               table_base_url={{ table_base_url }}
                               form_base_url={{ form_base_url }}
                               table_target_id={{ table_target_id }}
                               editable={{ editable }}
                               extra_params={{ extra_params }}
                               page_size={{ page_size }} />
  {% if page_size > 0 %}
    <shared.cards.Pagination />
    </div>
  {% endif %}
{% else %}
  <p class="text-base-content/60 italic">No {{ table_type_name | lower }} yet.</p>
{% endif %}

{% if editable %}
  <shared.crud.DeleteConfirmModal table_type_item_name={{ table_type_item_name }}
                                  table_target_id={{ table_target_id }} />
{% endif %}
