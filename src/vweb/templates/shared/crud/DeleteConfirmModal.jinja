{#def
    table_type_item_name: str,
    table_target_id: str,
#}
<dialog id="delete-modal-{{ table_target_id }}" class="modal">
  <div class="modal-box">
    <h3 class="text-lg font-bold">Confirm Delete</h3>
    <p class="py-4">
      Are you sure you want to delete this {{ table_type_item_name | lower }}? This cannot be undone.
    </p>
    <div class="modal-action">
      <button type="button" class="btn btn-ghost" hx-on:click="this.closest('dialog').close()">Cancel</button>
      <button id="delete-confirm-btn-{{ table_target_id }}"
              class="btn btn-error"
              hx-target="#{{ table_target_id }}"
              hx-swap="innerHTML"
              hx-on:click="this.closest('dialog').close()">Delete</button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
