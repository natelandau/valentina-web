{#def
    table_url: str,
    table_target_id: str,
#}
{# Post-mutation loading snippet: immediately re-GET the table so the swap shows fresh API data. #}
<div hx-get="{{ table_url }}"
     hx-trigger="load"
     hx-target="#{{ table_target_id }}"
     hx-swap="innerHTML">
    <div class="flex justify-center py-8">
        <span class="loading loading-spinner loading-lg"></span>
    </div>
</div>
