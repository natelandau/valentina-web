{#def
    campaign,
    active: str = ""
#}

{# Campaign chrome for subpages: compact strip + nav wrapped in the shared
   CampaignBand shell. Overview page uses CampaignBand directly with the full
   hero card as content instead. #}

<shared.layout.CampaignBand
    active={{ active }}
    campaign_id={{ campaign.id }}>
  <div class="surface-panel rounded-b-none px-4 sm:px-6">
    <shared.layout.CampaignStrip campaign={{ campaign }} />
  </div>
</shared.layout.CampaignBand>
