{#def company #}

{% set ctx = global_context() %}
<div class="rounded-t-box bg-gradient-to-br from-neutral to-neutral/85 text-neutral-content px-4 sm:px-6 py-5">
  <h1 class="font-serif text-2xl sm:text-3xl tracking-wide">{{ company.name }}</h1>
  {% if company.description %}
    <p class="text-neutral-content/70 mt-1">{{ company.description }}</p>
  {% endif %}
  <div class="flex flex-wrap gap-x-6 gap-y-1 mt-3 text-sm text-neutral-content/80">
    <span><span class="font-semibold">{{ ctx.users | length }}</span> members</span>
    <span><span class="font-semibold">{{ ctx.campaigns | length }}</span> campaigns</span>
    <span><span class="font-semibold">{{ ctx.characters | length }}</span> characters</span>
  </div>
</div>
