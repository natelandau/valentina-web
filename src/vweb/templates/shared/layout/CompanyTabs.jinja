{#def active="campaigns" #}

{% set pending = global_context().pending_user_count %}
<div role="tablist" class="tabs tabs-border" hx-boost="true" hx-swap="innerHTML show:no-scroll transition:true" hx-target="body">
  <a role="tab"
     class="tab {% if active == 'campaigns' %}tab-active font-semibold{% endif %}"
     href="{{ url_for('company_hub.home') }}">Campaigns</a>
  <a role="tab"
     class="tab {% if active == 'members' %}tab-active font-semibold{% endif %}"
     href="{{ url_for('admin.users') }}">
    Members
    {% if pending > 0 %}
      <shared.PingBadge extra_class="ml-2" />
    {% endif %}
  </a>
  <a role="tab"
     class="tab {% if active == 'settings' %}tab-active font-semibold{% endif %}"
     href="{{ url_for('admin.settings') }}">Settings</a>
  <a role="tab"
     class="tab {% if active == 'audit_log' %}tab-active font-semibold{% endif %}"
     href="{{ url_for('admin.audit_log') }}">Audit log</a>
</div>
