{#def
    category: FullSheetTraitCategory,
    post_url: str = "",
#}

{% set has_available = category.subcategories | selectattr("available_traits") | list %}

{% if has_available %}
  <tr>
    <td></td>
    <td class="flex justify-end">
      <form hx-post="{{ post_url }}" method="post">
        <div class="join">
          <select name="ADD_UNASSIGNED" class="select select-sm w-32">
            <option disabled selected>Add New Trait</option>
            {% for subcategory in category.subcategories if subcategory.available_traits %}
              <optgroup label="{{ subcategory.name | title }}"
                        class="font-semibold pt-2 border-t border-base-content/20 mt-2">
                {% for trait in subcategory.available_traits %}
                  <option value="{{ trait.id }}">{{ trait.name | title }}</option>
                {% endfor %}
              </optgroup>
            {% endfor %}
          </select>
          <button class="btn btn-sm btn-outline btn-primary" type="submit">
            Add
          </button>
        </div>
      </form>
    </td>
  </tr>
{% endif %}
