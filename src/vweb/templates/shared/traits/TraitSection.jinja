{#def
    section: FullSheetTraitSection,
    post_url: str,
#}
{# HTMX-driven variant for live character sheets; Alpine sibling: routes/character_create/templates/character_create/manual/components/TraitSection.jinja #}

<div class="divider text-lg uppercase tracking-wide font-semibold text-base-content/75">
  {{ section.name | title }}
</div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  {% for category in section.categories %}
    <shared.traits.TraitCategory section_name={{ section.name }} category={{ category }} post_url={{ post_url }} />
  {% endfor %}
</div>
